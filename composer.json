{
    "name": "omega-mvc/omega-wp-framework",
    "description": "Omega WP Framework is a framework for creating WordPress plugins. It includes support for Database, Controllers, Validator, Routes, and more.",
    "version": "1.0.0",
    "type": "library",
    "license": "GPL-3.0",
    "authors": [
        {
            "name": "Adriano Giovannini",
            "homepage": "https://omega-mvc.github.io/"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "php-stubs/wordpress-stubs": "^6.9",
        "phpunit/phpunit": "^13.2",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Omega\\": "src/Omega"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
